; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Apartment Anomaly Hotline"
config/description="Night hotline operator. Listen. Observe. Decide. Survive the shift."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://audio/default_bus_layout.tres"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
CallManager="*res://scripts/autoload/call_manager.gd"
CctvManager="*res://scripts/autoload/cctv_manager.gd"
ThreatManager="*res://scripts/autoload/threat_manager.gd"
DecisionManager="*res://scripts/autoload/decision_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
SettingsManager="*res://scripts/autoload/settings_manager.gd"
LocaleManager="*res://scripts/autoload/locale_manager.gd"
VoiceManager="*res://scripts/autoload/voice_manager.gd"
AnomalyRegistry="*res://scripts/autoload/anomaly_registry.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[gui]

theme/custom="res://ui/theme/game_theme.tres"

[input]

ui_pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
